generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

model ServiceInterest {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                  String           @id @default(cuid())
  fullName            String
  email               String
  serviceInterestText String
  message             String?
  sourcePage          String?
  ipAddress           String?
  userAgent           String?
  status              LeadStatus       @default(NEW)
  serviceInterestId   String?
  serviceInterest     ServiceInterest? @relation(fields: [serviceInterestId], references: [id], onDelete: SetNull)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([email])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  sourcePage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}
